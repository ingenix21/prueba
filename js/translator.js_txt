     'ckb' : ['Kurdo (Sorani)',''],
      'ky' : ['Kirg',''],
      'lo' : ['Laosiano',''],
      'la' : ['Latín',''],
      'lv' : ['Letón',''],
      'ln' : ['Lingala',''],
      'lt' : ['Lituano',''],
      'lg' : ['Luganda',''],
      'lb' : ['Luxemburgués',''],
      'mk' : ['Macedonio',''],
     'mai' : ['Maithili',''],
      'mg' : ['Malgache',''],
      'ms' : ['Malayo',''],
      'ml' : ['Malabar',''],
      'mt' : ['Maltés',''],
      'mi' : ['Maorí',''],
      'mr' : ['Marathi',''],
'mni-Mtei' : ['Meiteilon (manipuri)',''],
     'lus' : ['Mizo',''],
      'mn' : ['Mongol',''],
      'my' : ['Birmano',''],
      'ne' : ['Nepalí',''],
