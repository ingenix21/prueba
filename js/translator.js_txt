LANG_translate();

function LANG_translate() {
  var data, label, i, n, END = 0, PRE = 0, NOTR = 0, x, y, z;

  UTF8 = (document.querySelector('meta[charset]')||{'outerHTML':''}).outerHTML.toUpperCase().indexOf('UTF-8') +1;

  FLAG = '../js/flag/4x3';    // sinfonix/js (ISO-8859)
//   FLAG = 'images/flag/4x3';   // www/*       (UTF-8)

  languages = {
    'en' : ['English','us'],
    'es' : ['Español','es'],
    'fr' : ['Française','fr'],
    'pt' : ['Português','pt'],
    'de' : ['Deutsche','de'],
    'it' : ['Italiano','it'],
    'zh' : ['簡體中文','cn'],
    'hi' : ['हिंदी','in'],
    'ar' : ['عرب','ae'],
    'ru' : ['Русский','ru'],
  }
  if ( UTF8 ) {
    languages = {
   ...languages,
   ...{'af' : ['Afrikáans',''],
      'sq' : ['Albanés',''],
      'am' : ['Amárico',''],
      'hy' : ['Armenio',''],
